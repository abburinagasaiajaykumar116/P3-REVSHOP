<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console Appender for standard Spring output -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Prudent File Appender exclusively for AOP Logs -->
    <appender name="SHARED_AOP_FILE" class="ch.qos.logback.core.FileAppender">
        <file>c:/Users/Ajay/duplicate p3/logs/revshop-aop.log</file>
        <prudent>true</prudent>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level [USER-SERVICE] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root logger logs everything else to console -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <!-- Intercepts LoggingAspect outputs and routes them to the shared file -->
    <logger name="org.example.revshopuserservice.aop.LoggingAspect" level="INFO" additivity="false">
        <appender-ref ref="SHARED_AOP_FILE" />
        <appender-ref ref="CONSOLE" />
    </logger>

</configuration>
